{
  "id": "se01_transport_review",
  "label": "SE01 Transport Code Review",
  "description": "Hard-coded review flow for SE01 single-transport reviewer view.",
  "transportFieldId": "wnd[0]/usr/tabsMAINTABSTRIP/tabpTSSN/ssubCOMMONSUBSCREEN:RDDM0001:0210/ctxtTRDYSE01SN-TR_TRKORR",
  "transportCaretPosition": 10,
  "checkpoints": {
    "0": {
      "label": "Transport screen (transport opened)",
      "hint": "Numpad 0 jumps here. Numpad 1 continues into object review."
    },
    "1": {
      "label": "Tree expanded (programs visible)",
      "hint": "Numpad 1 jumps here. Numpad 5 opens default coding, Numpad + continues manually."
    }
  },
  "checkpoint0": {
    "label": "Open transport in SE01",
    "steps": [
      { "label": "Open SE01", "actions": [
        { "id": "wnd[0]/tbar[0]/okcd", "property": "Text", "value": "/nse01" },
        { "id": "wnd[0]", "method": "SendVKey", "args": [0] }
      ]},
      { "label": "Single transport tab", "actions": [
        { "id": "wnd[0]/usr/tabsMAINTABSTRIP/tabpTSSN", "method": "Select" }
      ]},
      { "label": "Enter transport number", "actions": [
        { "id": "{transportFieldId}", "property": "Text", "value": "{transport}" },
        { "id": "{transportFieldId}", "property": "CaretPosition", "value": "{transportCaretPosition}" }
      ]},
      { "label": "Press Enter", "actions": [
        { "id": "wnd[0]", "method": "SendVKey", "args": [0] }
      ]}
    ]
  },
  "step1": {
    "label": "Focus main transport and open reviewer view",
    "actions": [
      { "id": "wnd[0]/usr/lbl[20,9]", "method": "SetFocus" },
      { "id": "wnd[0]/usr/lbl[20,9]", "property": "CaretPosition", "value": 4 },
      { "id": "wnd[0]/tbar[1]/btn[41]", "method": "Press" }
    ]
  },
  "step2": {
    "label": "Expand object tree",
    "actions": [
      { "id": "wnd[0]/shellcont/shell", "method": "ExpandNode", "args": ["          5"] },
      { "id": "wnd[0]/shellcont/shell", "property": "TopNode", "value": "          1" },
      { "id": "wnd[0]/shellcont/shell", "method": "ExpandNode", "args": ["          6"] },
      { "id": "wnd[0]/shellcont/shell", "property": "TopNode", "value": "          1" }
    ],
    "defaultPath": {
      "label": "Open first listed coding",
      "actions": [
        { "id": "wnd[0]/shellcont/shell", "property": "SelectedNode", "value": "          7" },
        { "id": "wnd[0]/shellcont/shell", "method": "DoubleClickNode", "args": ["          7"] }
      ]
    }
  },
  "step3": {
    "label": "Open code comparison",
    "menu": {
      "label": "Choose compare menu",
      "actions": [
        { "id": "wnd[0]/mbar/menu[3]/menu[12]/menu[0]", "method": "Select" }
      ]
    },
    "viewUser": {
      "label": "View changed by user",
      "actions": [
        { "id": "wnd[0]/usr/cntlCONT/shellcont/shell/shellcont[0]/shell", "property": "CurrentCellColumn", "value": "USR" },
        { "id": "wnd[0]/usr/cntlCONT/shellcont/shell/shellcont[0]/shell", "method": "ClickCurrentCell" }
      ]
    },
    "openCompare": {
      "label": "Open compare column",
      "actions": [
        { "id": "wnd[1]/tbar[0]/btn[12]", "method": "Press" },
        { "id": "wnd[0]/usr/cntlCONT/shellcont/shell/shellcont[0]/shell", "property": "CurrentCellColumn", "value": "COMPARE" },
        { "id": "wnd[0]/usr/cntlCONT/shellcont/shell/shellcont[0]/shell", "method": "ClickCurrentCell" }
      ]
    }
  },
  "step4": {
    "label": "Scroll code differences",
    "hint": "Numpad 5 = next diff pair. Numpad + = back to transport / next transport.",
    "diffScroll": {
      "actions": [
        { "id": "wnd[0]/tbar[1]/btn[8]", "method": "Press" },
        { "id": "wnd[0]/tbar[1]/btn[7]", "method": "Press" }
      ]
    },
    "finish": {
      "label": "Close compare and return",
      "actions": [
        { "id": "wnd[1]/tbar[0]/btn[0]", "method": "Press" },
        { "id": "wnd[0]/tbar[0]/btn[3]", "method": "Press" },
        { "id": "wnd[0]/tbar[0]/btn[3]", "method": "Press" },
        { "id": "wnd[0]/tbar[0]/btn[3]", "method": "Press" },
        { "id": "wnd[0]/tbar[0]/btn[3]", "method": "Press" },
        { "id": "wnd[0]/usr/lbl[24,11]", "method": "SetFocus" },
        { "id": "wnd[0]/usr/lbl[24,11]", "property": "CaretPosition", "value": 6 }
      ]
    }
  },
  "hotkeys": {
    "checkpoint0": "Numpad0",
    "checkpoint1": "Numpad1",
    "action": "Numpad5",
    "continue": "NumpadAdd"
  }
}
