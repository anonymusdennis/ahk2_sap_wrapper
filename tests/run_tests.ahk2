#Requires AutoHotkey v2.0
#SingleInstance Off
; Headless test runner. No SAP GUI required: COM objects are simulated
; with plain AHK objects (see fakes below). Writes results to stdout and
; exits with a non-zero code when any assertion fails.
;
;   AutoHotkey64.exe /ErrorStdOut tests\run_tests.ahk2

#Include ..\src\SapWrapper2.ahk
#Include ..\src\Sm30BulkLoader.ahk
#Include ..\src\Sm30JsonConfig.ahk

Main()

; ---------------------------------------------------------------------------
; Tiny assertion harness
; ---------------------------------------------------------------------------

Out(text) {
    try {
        FileAppend(text "`n", "*", "UTF-8")
    } catch {
        OutputDebug(text)
    }
}

AssertEqual(actual, expected, label) {
    global TestFailures, TestCount
    TestCount += 1
    if (actual = expected) {
        return
    }
    TestFailures += 1
    Out("FAIL: " label " — expected '" expected "' got '" actual "'")
}

AssertTrue(condition, label) {
    AssertEqual(condition ? 1 : 0, 1, label)
}

; ---------------------------------------------------------------------------
; Fake COM infrastructure. SapComProxy._IsComObject is overridden in test
; subclasses so plain AHK objects tagged with isFakeCom are treated as COM.
; ---------------------------------------------------------------------------

class FakeCom {
    isFakeCom := true

    __New(typeName := "GuiUnknown") {
        this.Type := typeName
        this.children := Map()
    }

    FindById(id, raise := true) {
        if (this.children.Has(id)) {
            return this.children[id]
        }
        if (raise) {
            throw Error("not found: " id)
        }
        return 0
    }
}

class FakeCollectionCom {
    isFakeCom := true

    __New(items) {
        this.Type := "GuiComponentCollection"
        this.items := items
        this.Count := items.Length
        this.Length := items.Length
    }

    ; Only ElementAt is provided on purpose, to exercise the Item fallback.
    ElementAt(index) {
        return this.items[index + 1]
    }
}

class TestSapProxy extends SapComProxy {
    _IsComObject(value) {
        return IsObject(value) && value.HasOwnProp("isFakeCom")
    }
}

class TestCollectionProxy extends SapCollectionProxy {
    _IsComObject(value) {
        return IsObject(value) && value.HasOwnProp("isFakeCom")
    }
}

class RecordingPolicy extends SapHookPolicy2 {
    __New() {
        this.calls := []
        this.errors := []
        this.errorsEx := []
        this.retries := []
    }

    On_Call(op, typeName, member, path, args) {
        this.calls.Push(op ":" typeName "." member "@" path)
    }

    On_Error(op, typeName, member, path, args) {
        this.errors.Push(op ":" typeName "." member "@" path)
    }

    On_ErrorEx(info) {
        this.errorsEx.Push(info)
    }

    On_Retry(op, typeName, member, path, attempt) {
        this.retries.Push(member ":" attempt)
    }
}

; ---------------------------------------------------------------------------
; Allowlist / type registry tests
; ---------------------------------------------------------------------------

TestAllowlists() {
    ; GuiCTextField inherits Text through GuiTextField -> GuiVComponent.
    allow := SapTypeRegistry.GetAllowlist("GuiCTextField")
    AssertTrue(allow.Has("Text"), "GuiCTextField inherits Text from GuiVComponent")
    AssertTrue(allow.Has("CaretPosition"), "GuiCTextField inherits CaretPosition from GuiTextField")
    AssertTrue(allow.Has("Id"), "GuiCTextField inherits Id from GuiComponent")

    ; The heading typo 'theGuiVContainer' must not break GuiTableControl.
    tableAllow := SapTypeRegistry.GetAllowlist("GuiTableControl")
    AssertTrue(tableAllow.Has("GetCell"), "GuiTableControl declares GetCell")
    AssertTrue(tableAllow.Has("FindById"), "GuiTableControl inherits FindById via GuiVContainer chain")

    ; Case-insensitive strict lookups (COM is case-insensitive).
    AssertTrue(allow.Has("text"), "allowlist lookup is case-insensitive")

    ; TypeAsNumber fallback map.
    typeNumbers := SapGeneratedTypeNumbers.GetTypeNumberMap()
    AssertEqual(typeNumbers[31], "GuiTextField", "GuiComponentType 31 maps to GuiTextField")

    ; Missing type synthesized from the full API guide.
    textFieldAllow := SapTypeRegistry.GetAllowlist("GuiTextField")
    AssertTrue(textFieldAllow.Has("DisplayedText"), "GuiTextField has DisplayedText")
}

; ---------------------------------------------------------------------------
; Proxy pipeline tests
; ---------------------------------------------------------------------------

TestProxyPipeline() {
    policy := RecordingPolicy()
    root := FakeCom("GuiSession")
    child := FakeCom("GuiTextField")
    child.Text := "hello"
    root.children["wnd[0]/usr/txtFOO"] := child

    proxy := TestSapProxy(root, "GuiSession", "/app/con[0]/ses[0]", policy)

    wrapped := proxy.FindById("wnd[0]/usr/txtFOO")
    AssertTrue(IsObject(wrapped), "FindById result is wrapped")
    AssertEqual(wrapped._typeName, "GuiTextField", "wrapped child detected as GuiTextField")
    AssertEqual(Type(wrapped), "GuiTextField", "generated typed wrapper class used for child")
    AssertEqual(wrapped._path, "/app/con[0]/ses[0]/wnd[0]/usr/txtFOO", "child path is chained")
    AssertTrue(policy.calls.Length >= 1, "On_Call fired for FindById")
    AssertEqual(wrapped.Raw().Text, "hello", "raw child text readable")

    ; Error hooks: FindById of unknown id -> On_Error + On_ErrorEx(not-found).
    threw := false
    try {
        proxy.FindById("wnd[9]/missing")
    } catch {
        threw := true
    }
    AssertTrue(threw, "FindById failure rethrows")
    AssertTrue(policy.errors.Length >= 1, "On_Error fired for FindById failure")
    AssertTrue(policy.errorsEx.Length >= 1, "On_ErrorEx fired for FindById failure")
    if (policy.errorsEx.Length >= 1) {
        AssertEqual(policy.errorsEx[1]["reason"], "not-found", "FindById failure classified as not-found")
    }

    ; Strict mode blocks unknown members.
    strictProxy := TestSapProxy(root, "GuiSession", "/app", policy, true)
    strictThrew := false
    try {
        strictProxy.InvokeGet("DefinitelyNotAMember")
    } catch {
        strictThrew := true
    }
    AssertTrue(strictThrew, "strict mode blocks unknown member")
}

TestStaleRecovery() {
    policy := RecordingPolicy()
    root := FakeCom("GuiSession")
    stale := FakeCom("GuiTextField")
    fresh := FakeCom("GuiTextField")
    fresh.Text := "fresh"
    root.children["wnd[0]/usr/txtFOO"] := fresh

    ; Build the child proxy directly against the stale reference, with a
    ; recorded FindById origin pointing at the (now updated) parent.
    wrapped := TestSapProxy(stale, "GuiTextField", "/app/wnd[0]/usr/txtFOO", policy)
    wrapped.SetStaleRecovery(true)
    wrapped.DefineProp("_findParentCom", {Value: root})
    wrapped.DefineProp("_findId", {Value: "wnd[0]/usr/txtFOO"})

    ; The stale object has no Text property, so the first attempt fails and
    ; the proxy re-resolves via the parent.
    value := wrapped.InvokeGet("Text")
    AssertEqual(value, "fresh", "stale reference recovered via FindById origin")
    AssertTrue(policy.retries.Length >= 1, "On_Retry fired for stale recovery")
    AssertEqual(policy.errors.Length, 0, "no On_Error after successful recovery")
}

; ---------------------------------------------------------------------------
; Collection proxy tests
; ---------------------------------------------------------------------------

TestCollections() {
    policy := RecordingPolicy()
    items := [FakeCom("GuiTextField"), FakeCom("GuiTextField"), FakeCom("GuiTextField")]
    items[1].Name := "a"
    items[2].Name := "b"
    items[3].Name := "c"
    fakeCollection := FakeCollectionCom(items)

    collection := TestCollectionProxy(fakeCollection, "GuiComponentCollection", "/coll", policy)

    AssertEqual(collection.Count, 3, "collection Count")
    errorsBefore := policy.errors.Length
    first := collection[0]
    AssertEqual(policy.errors.Length, errorsBefore, "ElementAt fallback does not fire On_Error")
    AssertTrue(IsObject(first), "indexing returns wrapped item")
    AssertEqual(first.Raw().Name, "a", "indexing returns first item")

    names := ""
    for item in collection {
        names .= item.Raw().Name
    }
    AssertEqual(names, "abc", "__Enum iterates all items in order")

    indexSum := 0
    for index, item in collection {
        indexSum += index
    }
    AssertEqual(indexSum, 3, "__Enum two-variable form yields 0-based indexes")
}

; ---------------------------------------------------------------------------
; CSV parser tests
; ---------------------------------------------------------------------------

TestCsvParser() {
    loader := Sm30BulkLoader.FromSession("")

    records := loader._ParseCsvText("a,b,c`r`n1,2,3`n", ",")
    AssertEqual(records.Length, 2, "basic CSV record count")
    AssertEqual(records[2][3], "3", "basic CSV field value")

    ; Escaped quotes must not desync the parser.
    records := loader._ParseCsvText('"say ""hi""",second,"th,ird"', ",")
    AssertEqual(records[1][1], 'say "hi"', "escaped quote inside quoted field")
    AssertEqual(records[1][2], "second", "field after escaped quote intact")
    AssertEqual(records[1][3], "th,ird", "delimiter inside quoted field")

    ; Newlines inside quoted fields.
    records := loader._ParseCsvText('"line1`nline2",x`nsecond,y', ",")
    AssertEqual(records.Length, 2, "multi-line quoted field record count")
    AssertEqual(records[1][1], "line1`nline2", "newline preserved in quoted field")
    AssertEqual(records[2][1], "second", "record after multi-line field")

    ; Blank lines skipped, empty quoted fields kept.
    records := loader._ParseCsvText('a,"",c`n`n`nx,y,z', ",")
    AssertEqual(records.Length, 2, "blank lines are skipped")
    AssertEqual(records[1][2], "", "empty quoted field preserved")

    ; Backward-compatible line API.
    fields := loader._ParseCsvLine('p,"q,r",s', ",")
    AssertEqual(fields.Length, 3, "_ParseCsvLine field count")
    AssertEqual(fields[2], "q,r", "_ParseCsvLine quoted delimiter")
}

; ---------------------------------------------------------------------------
; JSON parser tests
; ---------------------------------------------------------------------------

TestJsonParser() {
    parsed := Sm30JsonConfig.LoadText('{"id":"t1","n":2,"flag":true,"arr":[1,"two"],"nested":{"x":1}}')
    AssertEqual(parsed.id, "t1", "JSON string value")
    AssertEqual(parsed.n, 2, "JSON number value")
    AssertEqual(parsed.flag, true, "JSON boolean value")
    AssertEqual(parsed.arr.Length, 2, "JSON array length")
    AssertEqual(parsed.arr[2], "two", "JSON array element")
    AssertEqual(parsed.nested.x, 1, "JSON nested object")

    ; Non-identifier keys are sanitized instead of aborting the load.
    parsed := Sm30JsonConfig.LoadText('{"/WUE/FIELD-NAME":"v","2start":"w"}')
    AssertEqual(parsed._WUE_FIELD_NAME, "v", "slash/dash key sanitized")
    AssertEqual(parsed._2start, "w", "leading-digit key sanitized")
}

; ---------------------------------------------------------------------------

Main() {
    global TestFailures := 0
    global TestCount := 0

    TestAllowlists()
    TestProxyPipeline()
    TestStaleRecovery()
    TestCollections()
    TestCsvParser()
    TestJsonParser()

    Out(TestCount " assertions, " TestFailures " failures")
    if (TestFailures > 0) {
        ExitApp(1)
    }
    Out("OK")
    ExitApp(0)
}
